{
  "name": "@agentid/cli",
  "version": "0.1.0",
  "description": "CLI tool for AgentID — register agents, manage capabilities, and check reputation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibishal/agentid.git",
    "directory": "apps/cli"
  },
  "keywords": [
    "agentid",
    "cli",
    "ai-agents",
    "intuition",
    "trust-registry",
    "register",
    "stake"
  ],
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "type": "module",
  "bin": {
    "agentid": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy-agents": "tsx src/scripts/deploy-test-agents.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentid/sdk": "workspace:*",
    "commander": "^12.1.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.0",
    "viem": "^2.23.0",
    "graphql-request": "^7.1.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
