{
  "name": "@agentid/schema",
  "version": "0.1.0",
  "description": "ERC-8004 aligned JSON-LD schemas for AgentID",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibishal/agentid.git",
    "directory": "packages/schema"
  },
  "keywords": [
    "agentid",
    "erc-8004",
    "schema",
    "ai-agents",
    "intuition",
    "trust",
    "zod"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
