{
  "name": "@agentids/sdk",
  "version": "0.1.0",
  "description": "Core SDK for AgentID — create agents, capabilities, and stake on Intuition Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibishal/agentid.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "agentid",
    "sdk",
    "ai-agents",
    "intuition",
    "trust",
    "multivault",
    "erc-8004",
    "staking"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentids/schema": "workspace:*",
    "@agentids/graphql": "workspace:*",
    "viem": "^2.23.0",
    "graphql-request": "^7.1.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
