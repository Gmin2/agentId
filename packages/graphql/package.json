{
  "name": "@agentid/graphql",
  "version": "0.1.0",
  "description": "GraphQL queries for AgentID on Intuition Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibishal/agentid.git",
    "directory": "packages/graphql"
  },
  "keywords": ["agentid", "graphql", "intuition", "ai-agents", "trust-registry"],
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "graphql-request": "^7.1.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
